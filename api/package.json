{
  "name": "paybridge-api",
  "version": "0.1.0",
  "description": "PayBridge REST API -- Bitcoin L2 payment gateway on Stacks",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":   "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@stacks/network":      "^6.16.0",
    "@stacks/transactions": "^6.16.0",
    "bullmq":               "^5.7.0",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "ioredis":              "^5.3.2",
    "pg":                   "^8.11.5",
    "uuid":                 "^9.0.1"
  },
  "devDependencies": {
    "@types/cors":          "^2.8.17",
    "@types/express":       "^4.17.21",
    "@types/node":          "^20.12.0",
    "@types/pg":            "^8.11.5",
    "@types/uuid":          "^9.0.8",
    "nodemon":              "^3.1.0",
    "tsx":                  "^4.7.2",
    "typescript":           "^5.4.0"
  }
}