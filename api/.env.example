# Copy this to .env and fill in your values

# Server
PORT=3001

# Stacks Network: "mainnet" | "testnet" | "devnet"
STACKS_NETWORK=devnet

# Stacks API URL (devnet default)
STACKS_API_URL=http://localhost:3999

# Deployer private key (from your Clarinet devnet wallet)
# Get this from: clarinet console -> ::get_costs
DEPLOYER_PRIVATE_KEY=753b7cc01a1a2e86221266a154af739463fce51219d97e4f856cd7200c3d7a5001

# Contract deployer address (matches Clarinet.toml deployer)
CONTRACT_ADDRESS=ST4G7CW81NTPZWGRVK7RSMC5BETW75G14VP7QJBJ

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/paybridge

# Redis URL
